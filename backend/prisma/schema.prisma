generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DB_URL")
}

model User {
  id           Int      @id @default(autoincrement())
  fullName     String
  email        String   @unique
  password     String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  refreshToken String?
  profile      Profile?
}

model Profile {
  id                Int      @id @default(autoincrement())
  phone             String   @unique
  dob               DateTime
  preferredLanguage Language @default(ENGLISH)
  category          Category @default(STUDENT)
  state             State    @default(MAHARASHTRA)
  annualIncome      Int
  userId            Int      @unique
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  user              User     @relation(fields: [userId], references: [id])
}

enum Language {
  ENGLISH
  HINDI
  MARATHI
  TAMIL
  TELUGU
  BENGALI
}

enum Category {
  STUDENT
  FARMER
  WOMEN
  SENIOR_CITIZEN
  STARTUP_FOUNDER
}

enum State {
  MAHARASHTRA
  TAMIL_NADU
  KARNATAKA
  PUNJAB
  GUJARAT
  RAJASTHAN
}
